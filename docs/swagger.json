{
    "swagger": "2.0",
    "info": {
        "description": "API for accessing and exporting Jeppesen terminal charts",
        "title": "Marinvent Chart API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "https://github.com/marinvent/marivent",
            "email": "support@marinvent.local"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/chart-types": {
            "get": {
                "description": "Returns all available chart types from ctypes.dbf with codes, categories, and descriptions",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "charts"
                ],
                "summary": "List all chart types",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_api.ChartTypesResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/charts/{icao}": {
            "get": {
                "description": "Returns all charts for a given ICAO airport. Can be filtered by type (code or name) and search query.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "charts"
                ],
                "summary": "List charts for ICAO",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ICAO airport code (e.g., KJFK, EGLL)",
                        "name": "icao",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Chart type - can be code (1L, AP) or name (RNAV, ILS, AIRPORT). Looks up in ctypes.dbf",
                        "name": "type",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Search text to filter by PROC_ID (procedure name)",
                        "name": "search",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_api.ChartList"
                        }
                    }
                }
            }
        },
        "/api/v1/charts/{icao}/export/{filename}": {
            "get": {
                "description": "Exports a specific chart to PDF format. Returns the chart as a PDF file.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/pdf"
                ],
                "tags": [
                    "charts"
                ],
                "summary": "Export chart to PDF",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ICAO airport code",
                        "name": "icao",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Chart filename (e.g., KJFK225)",
                        "name": "filename",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "PDF file containing the chart",
                        "schema": {
                            "type": "file"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Returns API health status and version",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal_api.ChartInfo": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "chart_type": {
                    "type": "string"
                },
                "date_eff": {
                    "type": "string"
                },
                "filename": {
                    "type": "string"
                },
                "has_tcl": {
                    "type": "boolean"
                },
                "icao": {
                    "type": "string"
                },
                "proc_id": {
                    "type": "string"
                },
                "sheet_id": {
                    "type": "string"
                },
                "type_name": {
                    "type": "string"
                }
            }
        },
        "internal_api.ChartList": {
            "description": "Response containing list of charts for an ICAO",
            "type": "object",
            "properties": {
                "charts": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/internal_api.ChartInfo"
                    }
                },
                "icao": {
                    "type": "string"
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "internal_api.ChartType": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "code": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "internal_api.ChartTypesResponse": {
            "type": "object",
            "properties": {
                "total": {
                    "type": "integer"
                },
                "types": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/internal_api.ChartType"
                    }
                }
            }
        }
    }
}